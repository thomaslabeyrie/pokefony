{% extends 'base.html.twig' %}

{% block title %}
	Pokefony
{% endblock %}

{% block body %}

	{# <h2 class="text-center m-4">{{ pokedex.name | capitalize }} Pokédex</h2> #}

	<div class="container my-4">
		<div class="row g-5">
			{% for pokemon in pokedex %}
				<div class="col-12 col-sm-6 col-md-4 col-lg-3">
					<div class="card border-0 border-bottom rounded-0 h-100">
						<img class="card-img-top" src="{{ pokemon.sprites.other['official-artwork'].front_default }}" alt="{{ pokemon.name | capitalize}} artwork">

						<div class="card-body">
							<div class="d-flex justify-content-between align-items-center">
								<h5 class="card-title m-0">
									<a href="" class="stretched-link text-decoration-none text-dark">
										{{ pokemon.name | title }}
									</a>
								</h5>

								<div class="d-flex gap-2">
									{% for entry in pokemon.types %}
										<span
											class="type-badge"
											style="background-color: var(--{{ entry.type.name }})"></span>
									{% endfor %}
								</div>
							</div>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
	</div>
{% endblock %}
