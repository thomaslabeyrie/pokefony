{% extends 'base.html.twig' %}

{% block title %}
	Pokefony
{% endblock %}

{% block body %}

	{# <h2 class="text-center m-4">{{ pokedex.name | capitalize }} Pokédex</h2> #}

	<div class="container my-4">
		<div class="row g-5">
			{% for pokemon in pokemons %}
				<div class="col-12 col-sm-6 col-md-4 col-lg-2">
					<div class="card border-0 border-bottom rounded-0 h-100 bg-transparent">
						<img class="card-img-top" src="{{ pokemon.sprites.other['official-artwork'].front_default }}" alt="{{ pokemon.name | capitalize}} artwork">

						<div class="card-body">
							<div class="d-flex justify-content-center align-items-center">
								<h5 class="card-title m-0">
									<a href="{{ path('app_pokemon_show', { name: pokemon.name }) }}" class="stretched-link text-decoration-none text-dark fw-semibold">
										{{ pokemon.name | replace({'-': ' '}) | title }}
									</a>
								</h5>
							</div>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
		<div class="container d-flex justify-content-center gap-2 my-5">
			<a class="btn btn-primary" href="{{ path('app_pokedex_region', { region: region, page: page - 1 }) }}">
				Previous
			</a>

			<a class="btn btn-primary" href="{{ path('app_pokedex_region', { region: region, page: page + 1 }) }}">
				Next
			</a>
		</div>
	</div>
{% endblock %}
