{% extends 'base.html.twig' %}

{% block title %}
	Pokefony
{% endblock %}

{% block body %}
	<div
		class="container-fluid container-md w-100 my-4" style="max-width: 800px;">
		{# Pagination #}
		<div class="d-flex justify-content-center gap-2 my-2">
			<nav aria-label="Page navigation">
				<ul
					class="pagination">
					{# Previous #}
					<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
						<a class="page-link" href="{{ page > 1 ? path('app_pokedex_region', { region: region, page: page - 1 }) : '#' }}">
							Previous
						</a>
					</li>

					{# Pages autour de la page actuelle #}
					{% for i in range(max(1, page - 2), page + 2) %}
						<li class="page-item {{ page == i ? 'active' : '' }}">
							<a class="page-link" href="{{ path('app_pokedex_region', { region: region, page: i }) }}">
								{{ i }}
							</a>
						</li>
					{% endfor %}

					{# Next - toujours actif car on ne connaît pas la dernière page #}
					<li class="page-item">
						<a class="page-link" href="{{ path('app_pokedex_region', { region: region, page: page + 1 }) }}">
							Next
						</a>
					</li>
				</ul>
			</nav>
		</div>

		<section class="p-0 p-md-4 rounded" data-controller="favorite-toast">
			<table class="table table-hover border-bottom mb-0">
				<tbody>
					{% for pokemon in pokemons %}
						<tr class="position-relative align-middle">
							<th scope="row" class="p-3 ps-md-2 text-center">
								<img src="{{ pokemon.artwork }}" class="img-fluid" style="width: 48px; height: 48px;" alt="{{ pokemon.name }}">
							</th>

							<td class="align-middle fw-bold py-3">
								<a class="text-reset text-decoration-none" href="{{ path('app_pokemon_show', { name: pokemon.name }) }}">
									{{ pokemon.name | title }}
								</a>
							</td>

							{% if app.user %}
								<td class="align-middle py-3">
									<turbo-frame id="favorite-{{ pokemon.id }}">
										{% include 'favorites/_favorite_button.html.twig' with { pokemon: pokemon, isFavorite: pokemon.id in favoriteIds } %}
									</turbo-frame>
								</td>
							{% endif %}

							<td class="align-middle py-3">
								{% for type in pokemon.types %}
									<span class="badge fs-10 mb-1" style="background-color: var(--{{ type }})">
										{{ type | upper }}
									</span>
								{% endfor %}
							</td>

							<td class="small pe-3 pe-md-2 py-3">
								#
								{{- pokemon.id -}}
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</section>

		{# Pagination #}
		<div class="d-flex justify-content-center gap-2 my-5">
			<nav aria-label="Page navigation">
				<ul
					class="pagination">
					{# Previous #}
					<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
						<a class="page-link" href="{{ page > 1 ? path('app_pokedex_region', { region: region, page: page - 1 }) : '#' }}">
							Previous
						</a>
					</li>

					{# Pages autour de la page actuelle #}
					{% for i in range(max(1, page - 2), page + 2) %}
						<li class="page-item {{ page == i ? 'active' : '' }}">
							<a class="page-link" href="{{ path('app_pokedex_region', { region: region, page: i }) }}">
								{{ i }}
							</a>
						</li>
					{% endfor %}

					{# Next - toujours actif car on ne connaît pas la dernière page #}
					<li class="page-item">
						<a class="page-link" href="{{ path('app_pokedex_region', { region: region, page: page + 1 }) }}">
							Next
						</a>
					</li>
				</ul>
			</nav>
		</div>
	</div>
{% endblock %}
