{% extends 'base.html.twig' %}

{% block title %}
	{{ pokemon.name | title }}
	- Pokefony
{% endblock %}

{% block body %}

	<div
		class="container">
		{# {{dump(pokemon)}} #}
		<div
			class="row my-4">

			{# Section Image #}
			<div class="col-12 col-lg-4">
				<section class="p-4 rounded h-100">
					<div class="d-flex h-100 flex-column justify-content-between align-items-center">
						<div class="h-100 d-flex align-items-center">
							<img src="{{ pokemon.sprites.officialArtwork }}" class="img-fluid" style="width: 300px;" alt="{{ pokemon.name | title }} artwork">
						</div>

						<div class="w-100">
							<div class="w-100 d-flex justify-content-between align-items-center">
								<h2 class="fw-bold">
									{{ pokemon.name | title }}
								</h2>

								<div class="d-flex gap-2">
									{% for type in pokemon.types %}
										<span class="badge fs-6" style="background-color: var(--{{ type.name }})">
											{{ type.name | upper }}
										</span>
									{% endfor %}
								</div>
							</div>

							<div class="w-100 d-flex justify-content-between align-items-center">
								<h6 class="fw-medium m-0">
									{{ pokemon.species.genera.genus | title }}
								</h6>

								<h6 class="text-muted m-0">
									#
									{{- pokemon.id | upper -}}
								</h6>
							</div>
						</div>
					</div>
				</section>
			</div>

			{# Section Informations #}
			<div class="col-12 col-lg-8">
				<section class="p-4 rounded h-100">
					<h6 class="section-title">
						Basic Information
					</h6>


					<table class="table mb-4">
						<tbody>
							<tr>
								<th scope="row">
									Height
								</th>
								<td>
									{{ pokemon.height / 10 }}
									m
								</td>
							</tr>

							<tr>
								<th scope="row">
									Weight
								</th>
								<td>
									{{ pokemon.weight / 10 }}
									kg
								</td>
							</tr>

							<tr>
								<th scope="row">
									Gender Ratio
								</th>
								<td class="align-middle">
									{% if pokemon.species.genderRate == -1 %}
										<span class="text-muted">
											Genderless
										</span>
									{% else %}
										{% set femalePercent = (pokemon.species.genderRate / 8 * 100) | number_format(1) %}
										{% set malePercent = ((8 - pokemon.species.genderRate) / 8 * 100) | number_format(1) %}
										<div class="progress rounded-5" style="height: 20px; max-width: 400px;">
											<div class="progress-bar bg-danger fw-medium" role="progressbar" style="width: {{ femalePercent }}%;" aria-valuenow="{{ femalePercent }}" aria-valuemin="0" aria-valuemax="100">
												{{ femalePercent }}
												%
											</div>
											<div class="progress-bar bg-primary fw-medium" role="progressbar" style="width: {{ malePercent }}%;" aria-valuenow="{{ malePercent }}" aria-valuemin="0" aria-valuemax="100">
												{{ malePercent }}
												%
											</div>
										</div>
									{% endif %}
								</td>
							</tr>

							<tr>
								<th scope="row">
									Abilities
								</th>

								<td class="align-middle">
									<div class="d-flex gap-2 flex-wrap">
										{% for ability in pokemon.abilities %}
											<span class="badge bg-secondary">
												{{ ability.name | replace({'-': ' '}) | title }}
												{% if ability.isHidden %}
													(Hidden)
												{% endif %}
											</span>
										{% endfor %}
									</div>
								</td>
							</tr>

							<tr>
								<th scope="row">
									Catch Rate
								</th>
								<td>
									{{ pokemon.species.captureRate }}
									<span class="text-muted">
										(
										{{- pokemon.species.captureRate * (100 / 255) | format_number({rounding_mode: 'floor'})-}}
										%)
									</span>
								</td>
							</tr>

							<tr>
								<th scope="row">
									Growth Rate
								</th>
								<td>
									{{ pokemon.species.growthRate | replace({'-': ' '}) | title }}
								</td>
							</tr>

							<tr>
								<th scope="row">
									Base Experience
								</th>
								<td>
									{{ pokemon.baseExperience }}
								</td>
							</tr>

							<tr>
								<th scope="row">
									Evolution Chain
								</th>
								<td>
									{% set evolutions = pokemon.evolutionChain.evolutions %}
									{% for index, evolution in evolutions %}
										{% if evolution.name != pokemon.name  %}
											<a class="link-primary text-decoration-none fw-semibold mx-1" href="{{ path('app_pokemon_show', { name: evolution.name }) }}">
												{{ evolution.name | title }}
											</a>
										{% else %}
											<span class="fw-semibold mx-1">
												{{ evolution.name | title }}
											</span>
										{% endif %}

										{% if index != evolutions | length - 1 %}
											<svg
												xmlns="http://www.w3.org/2000/svg"
												width="18"
												height="18"
												viewbox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
												class="lucide lucide-chevron-right-icon lucide-chevron-right">
												<path d="m9 18 6-6-6-6"/>
											</svg>
										{% endif %}
									{% endfor %}
								</td>
							</tr>
						</tbody>
					</table>


					<h6 class="section-title">
						Flavor Text
					</h6>

					<p class="fst-italic fw-medium my-1">
						{{ pokemon.species.flavorTextEntries['omega-ruby'] }}
					</p>
				</section>
			</div>
		</div>

		{# Types Section #}
		<section class="my-4 p-4 rounded">
			<h6 class="section-title">
				Type Effectiveness
			</h6>

			<table class="table  m-0">
				<tbody>
					<tr>
						<th scope="row" class="w-25 align-middle">
							Weak To
						</th>

						<td class="align-middle">
							<div class="d-flex gap-2 flex-wrap">
								{% if pokemon.effectiveness.weaknesses is empty %}
									<span class="text-muted">
										-
									</span>
								{% else %}
									{% for type, multiplier in pokemon.effectiveness.weaknesses %}
										<span class="badge fs-6" style="background-color: var(--{{ type }})">
											{{ type | upper }}
											x
											{{- multiplier -}}
										</span>
									{% endfor %}
								{% endif %}
							</div>
						</td>
					</tr>

					<tr>
						<th scope="row" class="w-25 align-middle">
							Resistant To
						</th>

						<td class="align-middle">
							<div class="d-flex gap-2 flex-wrap">
								{% if pokemon.effectiveness.resistances is empty %}
									<span class="text-muted">
										-
									</span>
								{% else %}
									{% for type, multiplier in pokemon.effectiveness.resistances %}
										<span class="badge fs-6" style="background-color: var(--{{ type }})">
											{{ type | upper }}
											x
											{{- multiplier -}}
										</span>
									{% endfor %}
								{% endif %}
							</div>
						</td>
					</tr>

					<tr>
						<th scope="row" class="w-25 align-middle">
							Immune To
						</th>

						<td class="align-middle">
							<div class="d-flex gap-2 flex-wrap">
								{% if pokemon.effectiveness.immunities is empty %}
									<span class="text-muted">
										-
									</span>
								{% else %}
									{% for type in pokemon.effectiveness.immunities %}
										<span class="badge fs-6" style="background-color: var(--{{ type }})">
											{{ type | upper }}
										</span>
									{% endfor %}
								{% endif %}
							</div>
						</td>
					</tr>
				</tbody>
			</table>
		</section>

		{# Section Evolution Chain #}
		<section class="my-4 p-4 rounded">
			<h6 class="section-title">
				Evolution Chain
			</h6>

			<table class="table">
				<tbody>
					{# Ligne des noms #}
					<tr>
						<th scope="row">
							Evolution
						</th>
						{% for evolution in pokemon.evolutionChain.evolutions %}
							<td class="fw-bold">
								{% if evolution.name != pokemon.name %}
									<a href="{{ path('app_pokemon_show', { name: evolution.name }) }}" class="text-decoration-none">
										{{ evolution.name | title }}
									</a>
								{% else %}
									{{ evolution.name | title }}
								{% endif %}
							</td>
						{% endfor %}
					</tr>

					{# Trigger - toujours affiché #}
					<tr>
						<th scope="row">
							Trigger
						</th>
						{% for evolution in pokemon.evolutionChain.evolutions %}
							<td>
								{% if evolution.evolutionDetails %}
									{{ evolution.evolutionDetails.trigger | replace({'-': ' '}) | title }}
								{% endif %}
							</td>
						{% endfor %}
					</tr>

					{# Min Level - seulement si au moins un Pokémon l'utilise #}
					{% set hasMinLevel = false %}
					{% for evolution in pokemon.evolutionChain.evolutions %}
						{% if evolution.evolutionDetails and evolution.evolutionDetails.minLevel %}
							{% set hasMinLevel = true %}
						{% endif %}
					{% endfor %}

					{% if hasMinLevel %}
						<tr>
							<th scope="row">
								Min Level
							</th>
							{% for evolution in pokemon.evolutionChain.evolutions %}
								<td>
									{% if evolution.evolutionDetails and evolution.evolutionDetails.minLevel %}
										{{ evolution.evolutionDetails.minLevel }}
									{% endif %}
								</td>
							{% endfor %}
						</tr>
					{% endif %}

					{# Item - seulement si utilisé #}
					{% set hasItem = false %}
					{% for evolution in pokemon.evolutionChain.evolutions %}
						{% if evolution.evolutionDetails and evolution.evolutionDetails.item %}
							{% set hasItem = true %}
						{% endif %}
					{% endfor %}

					{% if hasItem %}
						<tr>
							<th scope="row">
								Item
							</th>
							{% for evolution in pokemon.evolutionChain.evolutions %}
								<td>
									{% if evolution.evolutionDetails and evolution.evolutionDetails.item %}
										{{ evolution.evolutionDetails.item | replace({'-': ' '}) | title }}
									{% endif %}
								</td>
							{% endfor %}
						</tr>
					{% endif %}

					{# Min Happiness - seulement si utilisé #}
					{% set hasMinHappiness = false %}
					{% for evolution in pokemon.evolutionChain.evolutions %}
						{% if evolution.evolutionDetails and evolution.evolutionDetails.minHappiness %}
							{% set hasMinHappiness = true %}
						{% endif %}
					{% endfor %}

					{% if hasMinHappiness %}
						<tr>
							<th scope="row">
								Happiness
							</th>
							{% for evolution in pokemon.evolutionChain.evolutions %}
								<td>
									{% if evolution.evolutionDetails and evolution.evolutionDetails.minHappiness %}
										{{- evolution.evolutionDetails.minHappiness | replace({'-': ' '}) | title -}}
										+
									{% endif %}
								</td>
							{% endfor %}
						</tr>
					{% endif %}

					{# Time Of Day - seulement si utilisé #}
					{% set hasTimeOfDay = false %}
					{% for evolution in pokemon.evolutionChain.evolutions %}
						{% if evolution.evolutionDetails and evolution.evolutionDetails.timeOfDay %}
							{% set hasTimeOfDay = true %}
						{% endif %}
					{% endfor %}

					{% if hasTimeOfDay %}
						<tr>
							<th scope="row">
								Time
							</th>
							{% for evolution in pokemon.evolutionChain.evolutions %}
								<td>
									{% if evolution.evolutionDetails and evolution.evolutionDetails.timeOfDay %}
										{{ evolution.evolutionDetails.timeOfDay | replace({'-': ' '}) | title }}
									{% endif %}
								</td>
							{% endfor %}
						</tr>
					{% endif %}

					{# Held Item - seulement si utilisé #}
					{% set hasHeldItem = false %}
					{% for evolution in pokemon.evolutionChain.evolutions %}
						{% if evolution.evolutionDetails and evolution.evolutionDetails.heldItem %}
							{% set hasHeldItem = true %}
						{% endif %}
					{% endfor %}

					{% if hasHeldItem %}
						<tr>
							<th scope="row">
								Held Item
							</th>
							{% for evolution in pokemon.evolutionChain.evolutions %}
								<td>
									{% if evolution.evolutionDetails and evolution.evolutionDetails.heldItem %}
										{{ evolution.evolutionDetails.heldItem | replace({'-': ' '}) | title }}
									{% endif %}
								</td>
							{% endfor %}
						</tr>
					{% endif %}

					{# Known Move - seulement si utilisé #}
					{% set hasKnownMove = false %}
					{% for evolution in pokemon.evolutionChain.evolutions %}
						{% if evolution.evolutionDetails and evolution.evolutionDetails.knownMove %}
							{% set hasKnownMove = true %}
						{% endif %}
					{% endfor %}

					{% if hasKnownMove %}
						<tr>
							<th scope="row">
								Known Move
							</th>
							{% for evolution in pokemon.evolutionChain.evolutions %}
								<td>
									{% if evolution.evolutionDetails and evolution.evolutionDetails.knownMove %}
										{{ evolution.evolutionDetails.knownMove | replace({'-': ' '}) | title }}
									{% endif %}
								</td>
							{% endfor %}
						</tr>
					{% endif %}

					{# Location - seulement si utilisé #}
					{% set hasLocation = false %}
					{% for evolution in pokemon.evolutionChain.evolutions %}
						{% if evolution.evolutionDetails and evolution.evolutionDetails.location %}
							{% set hasLocation = true %}
						{% endif %}
					{% endfor %}

					{% if hasLocation %}
						<tr>
							<th scope="row">
								Location
							</th>
							{% for evolution in pokemon.evolutionChain.evolutions %}
								<td>
									{% if evolution.evolutionDetails and evolution.evolutionDetails.location %}
										{{ evolution.evolutionDetails.location | replace({'-': ' '}) | title }}
									{% endif %}
								</td>
							{% endfor %}
						</tr>
					{% endif %}


				</tbody>
			</table>
		</section>

		{# Section Stats #}
		<section class="my-4 p-4 rounded">
			<h6 class="section-title">
				Stats
			</h6>

			<table class="table table-borderless m-0" style="table-layout: fixed;">
				<colgroup>
					<col style="width: 80px;">
					<col style="width: 60px;">
					<col>
				</colgroup>

				<tbody>
					{% for stat in pokemon.stats %}
						<tr>
							<th scope="row">
								{{ stat.name | replace({'-': ' ', 'defense': 'def', 'attack': 'atk', 'special': 'spe'}) | title | replace({'Hp': 'HP'})}}
							</th>

							<td class="text-center fw-semibold">
								{{ stat.baseStat }}
							</td>

							<td class="align-middle">
								<div class="progress" style="height: 12px;">
									<div class="progress-bar" style="width: {{ stat.baseStat / 2.55 }}%" role="progressbar" aria-valuenow="{{ stat.baseStat }}" aria-valuemin="0" aria-valuemax="255"></div>
								</div>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</section>
	</div>
{% endblock %}
