{# Reusable Pokemon table component #}
<table class="table table-hover mb-0">
    <tbody>
        {% for row in rows %}
            <tr class="position-relative align-middle">
                <th scope="row" class="p-3 ps-md-2 text-center">
                    <img src="{{ row.sprite.url }}" class="img-fluid" style="width: 48px; height: 48px;" alt="{{ row.name }}">
                </th>

                <td class="align-middle fw-bold py-3">
                    <a class="text-reset text-decoration-none" href="{{ path('app_pokemon_show', { name: row.name }) }}">
                        {{ row.name|title }}
                    </a>
                </td>

                <td class="align-middle py-3">
                    {% for type in row.types %}
                        <span class="badge fs-10 mb-1" style="background-color: var(--{{ type }})">
                            {{ type|upper }}
                        </span>
                    {% endfor %}
                </td>

                <td class="small pe-3 pe-md-2 py-3">
                    #
                    {{- row.pokedexNumber -}}
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
